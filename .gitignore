# Python
venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# Data — tracked by DVC not Git
# Data files — tracked by DVC not Git
data/raw/*.jsonl
data/raw/*.csv
data/raw/*.parquet
data/processed/*.parquet
data/processed/*.csv
data/reference/*.parquet

# But DO commit .dvc pointer files and .gitignore files
!data/**/*.dvc
!data/**/.gitignore


# Models — tracked by MLflow not Git
models/
*.pkl
*.joblib
*.onnx

# Environment
.env
*.env.local

# IDE
.vscode/
.idea/

# MLflow local
mlruns/
mlartifacts/

# DVC
.dvc/cache/